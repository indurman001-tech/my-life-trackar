# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development
# In Vercel: add these in Project Settings → Environment Variables
# NEVER commit the real values to Git!
# ─────────────────────────────────────────────────────────────

# From supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co

# Use the service_role key (NOT anon) — it bypasses RLS safely on server
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
